{
  "name": "feranime-resolver",
  "description": "Personal-use resolver backend for the FerAnime native iOS app.",
  "repository": "https://github.com/edfwasd1234/FerAnimeNative",
  "keywords": ["node", "ios", "resolver", "anime"],
  "scripts": {
    "postdeploy": "node -e \"console.log('FerAnime resolver deployed')\""
  },
  "env": {
    "NODE_ENV": {
      "description": "Node runtime mode.",
      "value": "production"
    }
  },
  "expo": {
    "name": "FerAnime",
    "slug": "feranime",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "feranime",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.feranime.app"
    },
    "android": {
      "package": "com.feranime.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-video",
      "expo-font",
      "expo-router"
    ]
  }
}
